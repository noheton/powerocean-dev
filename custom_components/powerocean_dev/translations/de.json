                    "device_selection": "Erkanntes Gerät",
                    "device_id": "Seriennummer des Wechselrichters (wie in der EcoFlow-App angezeigt)",
                    "model_id": "PowerOcean-Modell"
                }
            },
            "device_options": {
                "description": "Geräteoptionen konfigurieren:",
                "data": {
                    "friendly_name": "Gerätename",
                    "scan_interval": "Aktualisierungsintervall (in Sekunden)"
                }
            },
            "reconfigure": {
                "description": "PowerOcean-Zugangsdaten aktualisieren.",
                "data": {
                    "device_id": "Seriennummer des Wechselrichters (wie in der EcoFlow-App angezeigt)",
