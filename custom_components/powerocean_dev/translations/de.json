{
    "config": {
        "step": {
            "user": {
                "description": "EcoFlow-Zugangsdaten eingeben. Verbundene PowerOcean-Geräte werden automatisch erkannt.",
                "data": {
                    "email": "E-Mail-Adresse",
                    "password": "Passwort"
                }
