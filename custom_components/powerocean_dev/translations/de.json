                "backend_url":   { "name": "Backend-URL",    "description": "Gleiche URL wie bei der Registrierung." },
                "sn":            { "name": "Charger-SN",     "description": "PowerPulse-Seriennummer. Wird automatisch erkannt, wenn leer." },
                "platform_code": { "name": "Plattform-Code" },
                "platform_name": { "name": "Plattform-Name" },
