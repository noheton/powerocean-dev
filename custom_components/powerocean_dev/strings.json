{
  "title": "EcoFlow PowerOcean",
  "config": {
    "step": {
      "user": {
        "description": "[%key:common::config_flow::data::description%]",
        "data": {
          "email": "[%key:common::config_flow::data::email%]",
          "password": "[%key:common::config_flow::data::password%]"
        }
      },
      "pick_device": {
        "description": "[%key:common::config_flow::data::description%]",
        "data": {
          "device_selection": "Discovered device",
          "device_id": "[%key:common::config_flow::data::device_id%]",
          "model_id": "[%key:common::config_flow::data::model_id%]"
        }
      },
      "device_options": {
        "description": "[%key:common::config_flow::data::description%]",
        "data": {
          "friendly_name": "[%key:common::config_flow::data::custom_device_name%]",
          "scan_interval": "[%key:common::config_flow::data::polling_interval%]"
        }
      },
      "reconfigure": {
        "description": "[%key:common::config_flow::reconfigure::description%]",
        "data": {
          "device_id": "[%key:common::config_flow::data::device_id%]",
          "email": "[%key:common::config_flow::data::email%]",
          "password": "[%key:common::config_flow::data::password%]",
          "model_id": "[%key:common::config_flow::data::model_id%]"
        }
      }
    },
    "error": {
      "cannot_connect": "[%key:common::config_flow::error::cannot_connect%]",
      "invalid_auth": "[%key:common::config_flow::error::invalid_auth%]",
      "unknown": "[%key:common::config_flow::error::unknown%]"
    },
    "abort": {
      "already_configured": "[%key:common::config_flow::abort::already_configured_device%]",
      "reconfiguration_completed": "[%key:common::config_flow::abort::reconfiguration_completed%]",
      "already_imported": "This device has already been imported from the original PowerOcean integration."
    }
  },
  "options": {
    "step": {
      "init": {
        "description": "[%key:common::config_flow::options::description%]",
        "data": {
          "friendly_name": "[%key:common::config_flow::data::custom_device_name%]",
          "scan_interval": "[%key:common::config_flow::data::polling_interval%]"
        }
      }
    }
  },
  "entity": {
    "sensor": {
      "sys_load_pwr":                   { "name": "House Load Power" },
      "sys_grid_pwr":                   { "name": "Grid Power (system)" },
      "mppt_pwr":                       { "name": "Solar Power (MPPT)" },
      "bp_pwr":                         { "name": "Battery Power" },
      "dcdc_pwr":                       { "name": "DC-DC Power" },
      "pcs_act_pwr":                    { "name": "Inverter Active Power" },
      "pcs_meter_power":                { "name": "PCS Meter Power" },
      "house_power":                    { "name": "House Power (calculated)" },
      "grid_power":                     { "name": "Grid Power" },
      "grid_to_battery":                { "name": "Grid to Battery" },
      "grid_to_house":                  { "name": "Grid to House" },
      "battery_to_house":               { "name": "Battery to House" },
      "solar_to_battery":               { "name": "Solar to Battery" },
      "solar_to_grid":                  { "name": "Solar to Grid" },
      "solar_to_house":                 { "name": "Solar to House" },
      "mppt_pv_pwr_total":              { "name": "Solar Total Power" },
      "pv1_pwr":                        { "name": "PV String 1 Power" },
      "pv2_pwr":                        { "name": "PV String 2 Power" },
      "pv3_pwr":                        { "name": "PV String 3 Power" },
      "pv_inv_pwr":                     { "name": "PV Inverter Power" },
      "other_pv_pwr":                   { "name": "Other PV Power" },
      "load_pwr":                       { "name": "Load Power" },
      "heating_power":                  { "name": "Heating Power" },
      "today_electricity_generation":   { "name": "Solar Yield Today" },
      "month_electricity_generation":   { "name": "Solar Yield This Month" },
      "year_electricity_generation":    { "name": "Solar Yield This Year" },
      "total_electricity_generation":   { "name": "Solar Yield Total" },
      "grid_out_day_energy":            { "name": "Grid Export Today" },
      "grid_in_day_energy":             { "name": "Grid Import Today" },
      "bp_in_day_energy":               { "name": "Battery Charge Today" },
      "bp_out_day_energy":              { "name": "Battery Discharge Today" },
      "load_day_energy":                { "name": "Load Energy Today" },
      "pv_in_day_energy":               { "name": "Solar Yield Today (EMS)" },
      "bp_total_chg_energy":            { "name": "Battery Lifetime Charged" },
