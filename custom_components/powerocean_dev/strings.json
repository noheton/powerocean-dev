      "pp_use_grid_first":              { "name": "Grid-First Mode" },
      "pp_ev_sn":                       { "name": "Charger Serial" },
      "pp_online_bits":                 { "name": "Online Flags" },
      "pp_charge_vehicle_id":           { "name": "Vehicle ID" },
      "pp_order_start_timestamp":       { "name": "Session Start (epoch s)" },
      "hr_pwr":                         { "name": "Heating Rod Power" },
      "hr_temp":                        { "name": "Water Temperature" },
      "hr_target_temp":                 { "name": "Target Water Temperature" },
      "module_sw_ver":                  { "name": "Firmware Version" },
      "system_name":                    { "name": "System Name" },
      "ems_bp_alive_num":               { "name": "Active Battery Modules" },
      "bp_online_sum":                  { "name": "Online Batteries" }
    },
    "binary_sensor": {
      "online":                         { "name": "Online" },
      "ems_bp_selfcheck":               { "name": "Battery Self-check Fault" },
      "ems_mppt_selfcheck":             { "name": "MPPT Self-check Fault" },
      "ems_mppt_run_state":             { "name": "MPPT Running" },
      "epo_switch_state":               { "name": "EPO Switch Active" },
      "auto_detect_start_power":        { "name": "Auto-detect Start Power" },
      "pv_to_inv_directly":             { "name": "PV Direct to Inverter" }
    },
    "button": {
      "system_reboot":                  { "name": "Reboot System" },
      "system_selfcheck":               { "name": "Run Self-check" }
    },
    "number": {
      "backup_reserve_soc":             { "name": "Backup Reserve SoC" },
      "fast_chg_max_soc":               { "name": "Fast Charge Upper Limit" },
      "charger_power_limit":            { "name": "Charger Power Limit" },
      "grid_in_pwr_limit":              { "name": "Grid Import Power Limit" },
      "charger_amp_limit":              { "name": "Charger Current Limit" }
    },
    "select": {
      "charger_mode": {
        "name": "Charger Mode",
        "state": {
          "auto": "Automatic",
          "fast": "Fast",
          "eco": "Economy"
        }
      },
      "backup_mode": {
        "name": "Backup Mode",
        "state": {
          "self_use":  "Self-use",
          "backup":    "Backup",
          "off":       "Off"
        }
      }
    },
    "switch": {
      "charger_enable":                 { "name": "EV Charger" },
      "grid_charge_enable":             { "name": "Grid Charging" },
      "system_pause":                   { "name": "System Pause" },
      "battery_heat":                   { "name": "Battery Heating" },
      "charger_auto_chg":               { "name": "Automatic EV Charging" }
    }
  },
  "services": {
    "set_tou_schedule": {
      "name": "Set TOU Schedule",
      "description": "Write a Time-of-Use strategy to the PowerOcean inverter.",
      "fields": {
        "schedule": {
          "name": "Schedule",
          "description": "TOU strategy JSON blob (cfgTouStrategy / cfgTouHoursStrategy)."
        }
      }
    },
    "set_grid_type": {
      "name": "Set Grid Type",
      "description": "Switch between single-phase and three-phase grid connection.",
      "fields": {
        "grid_type": {
          "name": "Grid Type",
          "description": "0 = single-phase, 1 = three-phase."
        }
      }
    }
  }
}
