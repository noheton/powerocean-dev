      "bp_soc":                         { "name": "Battery State of Charge" },
      "bp_soh":                         { "name": "Battery State of Health" },
      "bp_vol":                         { "name": "Battery Voltage" },
      "bp_amp":                         { "name": "Battery Current" },
      "bp_remain_watth":                { "name": "Battery Remaining Energy" },
      "bp_cycles":                      { "name": "Battery Cycles" },
      "bp_env_temp":                    { "name": "Battery Ambient Temperature" },
      "bp_min_cell_temp":               { "name": "Battery Min Cell Temperature" },
      "bp_max_cell_temp":               { "name": "Battery Max Cell Temperature" },
      "meter_a_voltage":                { "name": "Phase A Voltage" },
      "meter_b_voltage":                { "name": "Phase B Voltage" },
      "meter_c_voltage":                { "name": "Phase C Voltage" },
      "meter_a_current":                { "name": "Phase A Current" },
