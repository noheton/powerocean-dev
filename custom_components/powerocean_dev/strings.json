      "meter_power_factor":             { "name": "Power Factor" },
      "ev_pwr":                         { "name": "EV Charger Power" },
      "ev_charging_energy":             { "name": "EV Session Energy" },
      "charging_pwr":                   { "name": "Charging Power" },
      "pp_charging_status":             { "name": "Charging Status" },
      "pp_work_mode":                   { "name": "Charging Mode (raw)" },
      "pp_charge_target":               { "name": "Charge Target" },
      "pp_time_to_use_car":             { "name": "Time to Car Use" },
      "pp_allocated_power":             { "name": "Allocated Power" },
      "pp_feed_pwr_cap":                { "name": "Max Feed Power" },
      "pp_soc_cur":                     { "name": "Vehicle SoC" },
      "pp_switch_bits":                 { "name": "Control Flags" },
      "pp_user_current_set":            { "name": "User Current Setting" },
      "pp_current_ouput_max":           { "name": "Max Output Current" },
